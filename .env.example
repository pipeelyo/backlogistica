# Supabase → botón "Connect" en el proyecto → Postgres → Session o Transaction pooler.
#
# Evita el host directo db.PROJECT.supabase.co:5432 en redes sin IPv6: suele dar
# "getaddrinfo ENOTFOUND" porque ese nombre a menudo solo tiene registro AAAA (IPv6).
# El pooler (…pooler.supabase.com) sí suele resolver por IPv4.
#
# Transaction (6543), ejemplo (añade ?pgbouncer=true si el panel lo indica):
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
#
# Aviso del driver `pg` sobre sslmode=require: puedes usar ?sslmode=verify-full o
# ?uselibpqcompat=true&sslmode=require según la doc de pg en tu versión.

# Solo desarrollo: crea/altera tablas según entidades (no usar en producción).
TYPEORM_SYNC=false

# Supabase exige TLS; pon false solo en entornos locales muy concretos.
DATABASE_SSL=true

# Puerto HTTP (opcional)
PORT=3000

# Solo si tu red tiene IPv6 y quieres el host db.*.supabase.co a pesar del fallo ENOTFOUND en IPv4:
# DATABASE_USE_DIRECT_HOST=true

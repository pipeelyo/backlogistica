# Copie a ".env" y rellene. El resto de parámetros operativos están en `public.variable`
# (seed `database/15-seed-variables.sql`; consulta GET /catalogo/variables).

PORT=3000

# Postgres (Supabase → Project Settings → Database → URI del pooler :6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_SSL=true
TYPEORM_SYNC=false

# Supabase Auth / Storage / JWT
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Copie a ".env" y rellene. Nest carga .env desde el directorio de trabajo (raíz del repo al hacer nest start).

# Niveles del Logger de Nest (salida por consola). Por defecto: error,warn,log. Ejemplo con más detalle: LOG_LEVELS=error,warn,log,debug
# LOG_LEVELS=error,warn,log

# --- Cron: asignar repartidor a pedidos en estado pendiente; luego estado asignado. Código: cada 5 min pruebas; producción cambiar @Cron ---
# CRON_ASIGNAR_REPARTIDORES_ENABLED=true
# `estado_pedido` desde el que el cron puede asignar (sin repartidor). Por defecto solo pendiente.
# Si los pedidos quedan en «creado» y también deben asignarse, liste UUID separados por coma (p. ej. pendiente + PEDIDO_ESTADO_INICIAL_ID).
# UUID desde `select id_estado_pedido, nombre from estado_pedido` en Supabase.
# Sin ASIGNACION_ESTADOS_PEDIDO_ELEGIBLES el cron usa **pendiente** + **creado** (PEDIDO_ESTADO_INICIAL_ID).
# ASIGNACION_ESTADOS_PEDIDO_ELEGIBLES=0ed3e215-5388-4e9a-8a24-bab155939d99,e0c696a7-4b92-4568-9394-36d0af6579b0
# ASIGNACION_ESTADO_PEDIDO_PENDIENTE_ID=e0c696a7-4b92-4568-9394-36d0af6579b0
# ASIGNACION_ESTADO_PEDIDO_ASIGNADO_ID=7b125fe3-3c95-4483-be55-acf38838577e
# PEDIDO_ESTADO_INICIAL_ID=0ed3e215-5388-4e9a-8a24-bab155939d99
# Máximo de pedidos asignados por repartidor y por día de **fecha_entrega** (1–500; por defecto 5).
# ASIGNACION_MAX_ENTREGAS_POR_REPARTIDOR_DIA=5
# `rol.id_rol` del rol REPARTIDOR (seed 11-seed-rol.sql → 2). Opcional si cambia en BD.
# ASIGNACION_ROL_REPARTIDOR_ID=2
# Alias opcional: REPARTIDOR_ROL_ID=2
# JSON array: hub por repartidor (idUsuario). Ideal: **lat** y **lng** (WGS84) para km reales.
# Ej.: [{"idUsuario":"uuid-rep-1","lat":4.65,"lng":-74.05},{"idUsuario":"uuid-rep-2","idCiudad":1}]
# ASIGNACION_REPARTIDORES_HUBS=
# Coordenadas en `direccion` (recomendado): `database/optional-direccion-lat-long.sql` + lat/long al crear pedido.
# Opcional: geocodificar con OSM Nominatim direcciones sin lat/long (solo en memoria en esa corrida; ~1 req/s; no persiste en BD).
# ASIGNACION_GEOCODING_NOMINATIM=true
# Email de contacto obligatorio para User-Agent (política Nominatim).
# ASIGNACION_NOMINATIM_CONTACT_EMAIL=tu-correo@dominio.com

# --- Repartidor: aceptar pedido asignado → estado En Camino ---
# REPARTIDOR_PEDIDO_ESTADO_EN_CAMINO_ID=04e6c3bb-d0ab-4697-ba4c-b01000376cf0
# Estado previo requerido para POST /repartidor/pedidos/{id}/aceptar (por defecto = asignado del cron).
# REPARTIDOR_PEDIDO_ESTADO_ASIGNADO_ID=c5604927-4236-4672-abec-e3bbf768123d
# Tras POST /repartidor/pedidos/{id}/confirmar-entrega con EXITO o NOVEDADES.
# REPARTIDOR_PEDIDO_ESTADO_ENTREGADO_ID=aafaed49-7da9-40c9-8a2b-b8417aba3a5d
# Migración seguimiento + resultado_entrega: database/seguimiento-resultado-entrega.sql

# --- Supabase: fotos en base64 en POST /pedidos → bucket Storage "evidencias" ---
# Project Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxx.supabase.co
# Misma pantalla → service_role (secreto). NO use la clave "anon" aquí.
SUPABASE_SERVICE_ROLE_KEY=
# Dashboard → API → anon public (login/registro sesión desde la API)
SUPABASE_ANON_KEY=
# JWT Legacy Secret (Settings → JWT Keys → «Legacy JWT secret»): necesario si los access_token van con **HS256**.
SUPABASE_JWT_SECRET=
# Audience del access_token (por defecto `authenticated`). Solo aplica con JWT firmados vía **JWKS** (RS256/ES256).
# SUPABASE_JWT_AUDIENCE=authenticated

# Registro: si es false, Supabase puede exigir confirmación por correo antes de poder hacer login.
# REGISTER_EMAIL_AUTO_CONFIRM=true

# --- GET /pedidos?fecha=... (día civil del filtro; opcional) ---
# Vacío o ausente = America/Bogota (UTC−5). Use UTC para el comportamiento anterior solo en UTC.
# LIST_PEDIDOS_FECHA_TZ=UTC

# --- POST /pedidos: fk_estado_pedido al crear (por defecto estado "creado") ---
# PEDIDO_ESTADO_INICIAL_ID=ea973ee7-bb82-423c-b37e-5b6c28b484be
